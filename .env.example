# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_TEST_GUILD_ID=your_test_guild_id_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
# URL Discord redirect về sau OAuth (phải khớp với setting trong Discord Developer Portal)
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/callback

# PostgreSQL
POSTGRES_DB=dynamite_core
POSTGRES_USER=dynamite
POSTGRES_PASSWORD=change_me_strong_password

# JWT — dùng lệnh này để generate secret mạnh:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=generate_64_char_random_string_here
JWT_ISSUER=dynamite-api
JWT_AUDIENCE=dynamite-dashboard
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# CORS — origin của dashboard (production URL)
CORS_ORIGIN_0=https://yourdomain.com

# API
API_PORT=5000

# Dashboard
DASHBOARD_PORT=3000
VITE_API_URL=https://yourdomain.com
